{
  "version": 2,
  "functions": {
    "portfolio_project/portfolio_project/wsgi.py": {
      "runtime": "@vercel/python",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "portfolio_project/portfolio_project/wsgi.py"
    }
  ]
}
